[user]
  name = Ben McMurtrie
  email = {{ .email | quote }}

[core]
  editor = nvim

[init]
  defaultBranch = main

[merge]
  conflictstyle = zdiff3


[alias]
  s = status
  st = status --short --branch
  co = checkout
  br = branch
  

  d = diff
  dc = diff --cached
  ds = diff --stat

  l = log --oneline --graph --decorate
  ll = log --pretty=format:'%C(blue)%cd%Creset %C(cyan)(%cr)%Creset %C(yellow)%h%Creset %C(green)%an%Creset: %s %C(auto)%d%Creset' --date=format:'%Y-%m-%d %H:%M'
  lg = log --graph --decorate --pretty=format:'%C(yellow)%h%Creset %C(blue)%cd%Creset %C(cyan)(%cr)%Creset %C(green)%an%Creset: %s %C(auto)%d%Creset' --date=format:'%Y-%m-%d %H:%M'
  last = log -1 HEAD

  contributors = shortlog -sn

  a = add
  aa = add .
  ap = add -p

  unstage = restore --staged
  untrack = rm --cached

  amend = commit --amend
  fixup = commit --amend --no-edit

  c = commit
  cm = commit -m

  
  filelog = log -u
  uncommit = reset --soft HEAD~1

  remotes = remote -v
  branches = branch -a
  current = branch --show-current


[branch]
    sort = -committerdate

[color]
    ui = true

[color "branch"]
    current = blue
    local = yellow
    remote = green

[pull]
    rebase = true


[credential]
    helper =
    helper = /usr/local/share/gcm-core/git-credential-manager
[credential "https://dev.azure.com"]
    useHttpPath = true
[credential "https://github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
