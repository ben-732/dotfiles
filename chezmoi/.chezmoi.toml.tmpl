[edit]
  command  = "code"
  args     = ["-r", "--wait"]

[data]
  email = {{ promptStringOnce . "email" "Email address" "22252563+ben-732@users.noreply.github.com" | quote }}
	is_work_computer = {{ promptBoolOnce . "is_work_computer" "Is this a work computer?" false }}

[merge]
    command = "code"
    args = [
        "--wait",
        "--new-window",
        "--merge",
        '{{ "{{ .Destination }}" }}',
        '{{ "{{ .Target }}" }}',
        '{{ "{{ printf `%s.base` .Target }}" }}',
        '{{ "{{ .Source }}" }}',
    ]
