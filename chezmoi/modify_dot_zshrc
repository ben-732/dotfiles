#!/usr/bin/env bash
# Emit the chezmoi-managed section of ~/.zshrc, then preserve everything
# below the marker from the existing file (passed on stdin). Tools like
# Ansible can append below the marker without `chezmoi apply` clobbering it.

cat <<'EOF'
# plugins / completions
[[ -f ~/.config/zsh/env.zsh ]] && source ~/.config/zsh/env.zsh
[[ -f ~/.config/zsh/plugins.zsh ]] && source ~/.config/zsh/plugins.zsh

# aliases and functions
[[ -f ~/.config/zsh/aliases.zsh ]] && source ~/.config/zsh/aliases.zsh
[[ -f ~/.config/zsh/functions.zsh ]] && source ~/.config/zsh/functions.zsh

[[ -f ~/.config/zsh/prompt.zsh ]] && source ~/.config/zsh/prompt.zsh

# Local machine specific config
[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local

# -- End of chezmoi managed config --
EOF

awk '/^# -- End of chezmoi managed config --$/ {found=1; next} found'
